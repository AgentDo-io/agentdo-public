{
  "$schema": "https://modelcontextprotocol.io/schemas/manifest.json",
  "name": "agentdo",
  "displayName": "AgentDo",
  "description": "Search and book real-world services (restaurants, salons, providers) through AI agents.",
  "url": "https://mcp.agentdo.io",
  "homepage": "https://agentdo.me",
  "documentation": "https://github.com/AgentDo-io/agentdo-public/blob/main/docs/mcp-connection.md",
  "auth": {
    "type": "header",
    "header": "X-API-Key",
    "instructions": "Get your key at https://agentdo.io/dashboard"
  },
  "tools": [
    "search", "lookup", "availability",
    "book", "order", "quote", "price_check",
    "cancel", "status"
  ]
}
